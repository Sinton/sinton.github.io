---
import chinaMap from "@/data/china.geo.json";
import { travelFootprints, visitedProvinceNames } from "@/data/travelFootprints";

type Position = [number, number];
type Ring = Position[];
type Polygon = Ring[];
type MultiPolygon = Polygon[];

type ChinaFeature = {
  properties: {
    name: string;
  };
  geometry: {
    type: "Polygon" | "MultiPolygon";
    coordinates: Polygon | MultiPolygon;
  };
};

const features = chinaMap.features as unknown as ChinaFeature[];
const visited = new Set(visitedProvinceNames);
const width = 960;
const height = 660;
const padding = 26;

const eachPosition = (coords: unknown, callback: (position: Position) => void) => {
  if (!Array.isArray(coords)) return;
  const first = coords[0];
  if (typeof first === "number" && typeof coords[1] === "number") {
    callback(coords as Position);
    return;
  }
  coords.forEach((item) => eachPosition(item, callback));
};

const bounds = features.reduce(
  (box, feature) => {
    eachPosition(feature.geometry.coordinates, ([lng, lat]) => {
      box.minLng = Math.min(box.minLng, lng);
      box.maxLng = Math.max(box.maxLng, lng);
      box.minLat = Math.min(box.minLat, lat);
      box.maxLat = Math.max(box.maxLat, lat);
    });
    return box;
  },
  {
    minLng: Number.POSITIVE_INFINITY,
    maxLng: Number.NEGATIVE_INFINITY,
    minLat: Number.POSITIVE_INFINITY,
    maxLat: Number.NEGATIVE_INFINITY,
  },
);

const scale = Math.min(
  (width - padding * 2) / (bounds.maxLng - bounds.minLng),
  (height - padding * 2) / (bounds.maxLat - bounds.minLat),
);
const mapWidth = (bounds.maxLng - bounds.minLng) * scale;
const mapHeight = (bounds.maxLat - bounds.minLat) * scale;
const offsetX = (width - mapWidth) / 2;
const offsetY = (height - mapHeight) / 2;

const project = ([lng, lat]: Position) => ({
  x: offsetX + (lng - bounds.minLng) * scale,
  y: offsetY + (bounds.maxLat - lat) * scale,
});

const ringToPath = (ring: Ring) =>
  ring
    .map((point, index) => {
      const { x, y } = project(point);
      return `${index === 0 ? "M" : "L"}${x.toFixed(2)},${y.toFixed(2)}`;
    })
    .join(" ");

const polygonToPath = (polygon: Polygon) =>
  polygon.map((ring) => `${ringToPath(ring)} Z`).join(" ");

const featureToPath = (feature: ChinaFeature) => {
  if (feature.geometry.type === "Polygon") {
    return polygonToPath(feature.geometry.coordinates as Polygon);
  }
  return (feature.geometry.coordinates as MultiPolygon)
    .map((polygon) => polygonToPath(polygon))
    .join(" ");
};

const provincePaths = features.map((feature) => ({
  name: feature.properties.name,
  path: featureToPath(feature),
  visited: visited.has(feature.properties.name),
}));

const projectedPoints = travelFootprints.map((item) => ({
  ...item,
  ...project([item.lng, item.lat]),
}));
---

<figure class="footprint-panel footprint-panel--newspaper">
  <div class="footprint-panel__header">
    <span>方案 B</span>
    <h2>旧报纸版图</h2>
    <p>把足迹画成一张地理插图，更贴近这份晚报的气质。</p>
  </div>
  <div class="footprint-map footprint-map--newspaper">
    <svg viewBox={`0 0 ${width} ${height}`} role="img" aria-label="中国旅行足迹旧报纸版图">
      <defs>
        <pattern id="footprint-paper-lines" width="12" height="12" patternUnits="userSpaceOnUse">
          <path d="M0 0H12" />
        </pattern>
      </defs>
      <rect class="footprint-svg__paper-lines" width={width} height={height} />
      <g class="footprint-svg__provinces">
        {
          provincePaths.map((province) => (
            <path
              class:list={[
                "footprint-svg__province",
                province.visited && "footprint-svg__province--visited",
              ]}
              d={province.path}
            >
              <title>{province.name}</title>
            </path>
          ))
        }
      </g>
      <g class="footprint-svg__points">
        {
          projectedPoints.map((point) => (
            <a href={point.href} aria-label={`查看${point.place}远行记`}>
              <circle class="footprint-svg__point-ring" cx={point.x} cy={point.y} r="9" />
              <circle class="footprint-svg__point" cx={point.x} cy={point.y} r="4.5" />
              <text x={point.x + 9} y={point.y - 8}>{point.place}</text>
            </a>
          ))
        }
      </g>
    </svg>
  </div>
  <figcaption>线稿高亮的是去过的省区，红点是已经写成远行记的地点。</figcaption>
</figure>
