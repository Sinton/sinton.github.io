---
import "../../styles/personal-shared.css";
import "../../styles/personal-articles.css";
import { themeConfig } from "@/theme.config";
import { getCollection } from "astro:content";
import BaseLayout from "astro-newspaper-theme/layouts/BaseLayout.astro";
import Masthead from "astro-newspaper-theme/components/Masthead.astro";
import { formatDate, sortByDateDesc } from "astro-newspaper-theme/lib/format";

const articles = sortByDateDesc(await getCollection("articles"));
const primaryTags = [
  {
    label: "Java",
    tags: ["Java", "JVM", "并发", "线程池", "ThreadPoolExecutor", "锁升级", "synchronized", "虚拟线程", "Project Loom"],
  },
  {
    label: "AI",
    tags: ["AI"],
  },
  {
    label: "经济学",
    tags: ["经济学", "社会经济", "生产力", "稀缺性", "商业模式"],
  },
  {
    label: "数据库",
    tags: ["数据库", "MySQL", "InnoDB", "MVCC"],
  },
  {
    label: "分布式事务",
    tags: ["分布式事务", "一致性", "消息队列", "架构"],
  },
  {
    label: "社会观察",
    tags: ["社会观察", "职业", "裁员", "消费"],
  },
];

const articleTags = primaryTags
  .map((term) => {
    const count = articles.filter((article) =>
      term.tags.some((tag) => article.data.tags.includes(tag)),
    ).length;
    return { ...term, count };
  })
  .filter((term) => term.count > 0);

const categoryLabels: Record<string, string> = {
  Editorial: "编者按",
  Tech: "技术专栏",
  Economics: "经济观察",
};
---


<BaseLayout title="随笔栏" description="技术、产品、写作与生活观察" config={themeConfig}>
<Masthead config={themeConfig} />
  <main class="archive-page">
    <header class="archive-header">
      <h1 class="section-kicker archive-header__kicker-title">随笔栏</h1>
      <p>写作、技术、产品和生活观察都会进入这里，像报纸里的小专栏一样慢慢积累。</p>
    </header>
    <section class="article-index-layout" data-article-filter>
      <aside class="article-filter" aria-label="文章索引词">
        <div class="article-filter__header">
          <span class="section-kicker">主题</span>
        </div>
        <div class="article-filter__terms">
          <button type="button" class="is-active" data-filter-tag="all">
            <span>全部</span>
            <em>{articles.length}</em>
          </button>
          {
            articleTags.map((term) => (
              <button
                type="button"
                data-filter-tag={term.label}
                data-filter-tags={JSON.stringify(term.tags)}
              >
                <span>{term.label}</span>
                <em>{term.count}</em>
              </button>
            ))
          }
        </div>
      </aside>

      <section class="entry-list article-filter__list" aria-label="全部随笔">
        <div class="article-filter__list-heading">
          <span class="section-kicker article-filter__list-label" data-article-filter-label>
            全部随笔
          </span>
          <span class="sr-only" data-article-filter-count aria-live="polite">
            本栏检出 {articles.length} 篇
          </span>
        </div>
        {
          articles.map((article) => (
            <article
              class="entry-list__item"
              data-article-entry
              data-tags={JSON.stringify(article.data.tags)}
            >
              <a href={`/articles/${article.id}/`}>
                <span class="entry-list__date">{formatDate(article.data.date, themeConfig)}</span>
                <h3>{article.data.title}</h3>
                <p>{article.data.description}</p>
                <span class="entry-list__meta">
                  {categoryLabels[article.data.category] ?? article.data.category}
                </span>
              </a>
            </article>
          ))
        }
      </section>
    </section>
  </main>
</BaseLayout>

<script>
  const filterRoot = document.querySelector("[data-article-filter]");
  const entries = Array.from(
    document.querySelectorAll<HTMLElement>("[data-article-entry]"),
  );
  const countNode = document.querySelector("[data-article-filter-count]");
  const labelNode = document.querySelector("[data-article-filter-label]");

  if (filterRoot && countNode && labelNode) {
    const buttons = Array.from(
      filterRoot.querySelectorAll("[data-filter-tag]"),
    );

    const setActiveTag = (tag: string) => {
      let visibleCount = 0;

      const activeButton = buttons.find(
        (button) => button.getAttribute("data-filter-tag") === tag,
      );
      const filterTags = JSON.parse(
        activeButton?.getAttribute("data-filter-tags") || "[]",
      );

      entries.forEach((entry) => {
        const tags = JSON.parse(entry.getAttribute("data-tags") || "[]");
        const isVisible =
          tag === "all" ||
          filterTags.some((filterTag: string) => tags.includes(filterTag));
        entry.hidden = !isVisible;
        if (isVisible) visibleCount += 1;
      });

      buttons.forEach((button) => {
        button.classList.toggle(
          "is-active",
          button.getAttribute("data-filter-tag") === tag,
        );
      });

      countNode.textContent = `本栏检出 ${visibleCount} 篇`;
      labelNode.textContent = tag === "all" ? "全部随笔" : `索引词：${tag}`;
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        setActiveTag(button.getAttribute("data-filter-tag") || "all");
      });
    });
  }
</script>
