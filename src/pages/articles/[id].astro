---
import "../../styles/personal-shared.css";
import "../../styles/personal-articles.css";
import { themeConfig } from "@/theme.config";
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "astro-newspaper-theme/layouts/BaseLayout.astro";
import ArticleProgress from "astro-newspaper-theme/components/ArticleProgress.astro";
import ArticleReadMore from "astro-newspaper-theme/components/ArticleReadMore.astro";
import ArticleToc from "astro-newspaper-theme/components/ArticleToc.astro";
import Masthead from "astro-newspaper-theme/components/Masthead.astro";
import StampTag from "astro-newspaper-theme/components/StampTag.astro";
import { formatDate, sortByDateDesc } from "astro-newspaper-theme/lib/format";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"articles">;
}

const { entry } = Astro.props as Props;
const { Content, headings } = await render(entry);
const articleTags = entry.data.tags;
const tocHeadings = headings.filter((heading) => heading.depth === 2);
const articles = sortByDateDesc(await getCollection("articles"));
const currentIndex = articles.findIndex((article) => article.id === entry.id);
const newerArticle = currentIndex > 0 ? articles[currentIndex - 1] : null;
const olderArticle =
  currentIndex >= 0 && currentIndex < articles.length - 1
    ? articles[currentIndex + 1]
    : null;
const previousArticle = newerArticle
  ? {
      href: `/articles/${newerArticle.id}/`,
      title: newerArticle.data.title,
      date: newerArticle.data.date,
    }
  : null;
const nextArticle = olderArticle
  ? {
      href: `/articles/${olderArticle.id}/`,
      title: olderArticle.data.title,
      date: olderArticle.data.date,
    }
  : null;
const categoryLabels: Record<string, string> = {
  Editorial: "编者按",
  Tech: "技术专栏",
  Economics: "经济观察",
};
---

<BaseLayout title={entry.data.title} description={entry.data.description} config={themeConfig}>
  <Masthead config={themeConfig} />
  <main class="detail-page">
    <article class="column-page">
      <header class="column-page__header column-page__header--article">
        <StampTag
          label={categoryLabels[entry.data.category] ?? entry.data.category}
          tone="blue"
        />
        <h1>{entry.data.title}</h1>
        <p>{entry.data.description}</p>
        <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date, themeConfig)}</time>
        {
          articleTags.length > 0 && (
            <div class="article-index-terms" aria-label="文章索引词">
              <span class="article-index-terms__label">索引词</span>
              <span class="article-index-terms__list">{articleTags.join(" / ")}</span>
            </div>
          )
        }
      </header>
      <ArticleToc headings={tocHeadings} numberStyle={themeConfig.tocNumberStyle} label="本篇目次" />
      <ArticleProgress />
      <div class="prose" data-article-body>
        <Content />
      </div>
      {
        articles.length > 1 && (
          <ArticleReadMore
            indexHref="/articles/"
            indexLabel="返回随笔栏"
            label="继续翻阅"
            previous={previousArticle}
            next={nextArticle}
            config={themeConfig}
          />
        )
      }
    </article>
  </main>
</BaseLayout>